% swap <-> two vertices [graph/tree]
\def\VSwap#1#2#3#4{\path[draw](#1) edge[<->,#3,shorten >=#4pt,shorten <=#4pt] (#2){};}
\def\VArr#1#2#3#4{\path[draw](#1) edge[->,#3,shorten >=#4pt,shorten <=#4pt] (#2){};}

% swap <-> two edges [tree]
\def\ESwap#1#2#3#4#5{\VSwap{$(#1)!0.5!(#2)$}{$(#3)!0.5!(#4)$}{#5}{1.5}}
\def\ESwapOfs#1#2#3#4#5#6#7#8{\VSwap{$(#1)!0.5!(#2) + (#6)$}{$(#3)!0.5!(#4) + (#7)$}{#5}{#8}}
\def\ESwapPerc#1#2#3#4#5#6{\VSwap{$(#1)!#6!(#2)$}{$(#3)!#6!(#4)$}{#5}{1.5}}
\def\EArr#1#2#3#4#5{\VArr{$(#1)!0.5!(#2)$}{$(#3)!0.5!(#4)$}{#5}{1.5}}
\def\EArrOfs#1#2#3#4#5#6#7#8{\VArr{$(#1)!0.5!(#2) + (#6)$}{$(#3)!0.5!(#4) + (#7)$}{#5}{#8}}

\def\EdgeSign(#1)(#2)#3(#4)#5{
  \node at ($(#1)!#3!(#2) + (#4)$) [color=black, scale=\graphdslabelscale] {$\scriptstyle #5$};
}

