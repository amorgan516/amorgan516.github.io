\makeatletter
\def\hetype#1{\hbox{$\tn@main#1\tn@end\tn@end$}}
\def\tn@und#1#2{{\tn@dound #2\tn@end\tn@end}\tn@main}
\def\tn@tri#1#2#3{{\smash{\raise2pt\hbox{$\scriptscriptstyle #3$}}}\tn@main}
\def\tn@main#1{%
   \ifx#1\tn@end\relax\else   
   \ifx#1__\expandafter\tn@und\else
   \ifx#1^ ^\expandafter\tn@tri\else     
   \ifx#1.\hbox{$\cdot$}\else
   \ifx#1:\hbox{:}\else
   \ifx#1o\hbox{$\hspace{0.6pt}\circ\hspace{0.6pt}$}\else
   \ifx#1x\hbox{$\hspace{0.6pt}\times\hspace{0.6pt}$}\else   
   \ifx#1I\hbox{I}\else   
   \ifx#1U\hbox{U}\else   
   #1\fi\fi\fi\fi\fi\fi
   \expandafter\expandafter\expandafter\expandafter
   \expandafter\expandafter\expandafter\tn@main\fi\fi\fi}
\def\tn@dound#1{%
