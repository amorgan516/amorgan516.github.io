\def\TreeEdgeSignN(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(0,\TreeEdgeSignDist){#4}}
\def\TreeEdgeSignS(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(0,-\TreeEdgeSignDist){#4}}
\def\TreeEdgeSignW(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(-\TreeEdgeSignDist,0){#4}}
\def\TreeEdgeSignE(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(\TreeEdgeSignDist,0){#4}}
\def\GraphEdgeSignN(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(0,\GraphEdgeSignDist){#4}}
\def\GraphEdgeSignS(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(0,-\GraphEdgeSignDist){#4}}
\def\GraphEdgeSignW(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(-\GraphEdgeSignDist,0){#4}}
\def\GraphEdgeSignE(#1)(#2)#3#4{\EdgeSign(#1)(#2)#3(\GraphEdgeSignDist,0){#4}}
